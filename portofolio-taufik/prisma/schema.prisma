// Konfigurasi Client Prisma
generator client {
  provider = "prisma-client-js"
}

// Konfigurasi Database (Langsung menggunakan URL NeonDB kamu)
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Model User untuk Login Admin
model User {
  id       String @id @default(cuid())
  username String @unique
  password String // Password terenkripsi
}

model Project {
  id          String   @id @default(cuid())
  title       String
  description String
  techStack   String[]
  images      String[]
  liveDemoUrl String?
  githubUrl   String?  // <-- TAMBAHAN: Link GitHub
  features    String[] // <-- TAMBAHAN: List Fitur
  isTopProject Boolean  @default(false) // <-- TAMBAHAN: Fitur Top Project
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Setting {
  key   String @id
  value String
}